# Database
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost/b2p_db

# Security
SECRET_KEY=CHANGE_ME_IN_PROD
JWT_AUDIENCE=api.b2p.com
JWT_ISSUER=auth.b2p.com

# Token Lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_AUTH=30

# Account Lockout
MAX_FAILED_LOGIN_ATTEMPTS=5
LOCK_MINUTES=15

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Application
PROJECT_NAME=Byparsathy
API_V1_STR=/api/v1
