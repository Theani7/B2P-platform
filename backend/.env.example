# === Backend (Node.js + Express.js) ===
# Prisma connection string (PostgreSQL). Must use the prisma scheme: postgresql://
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/b2p_db
DATABASE_TEST_URL=postgresql://postgres:postgres@localhost:5432/b2p_test_db

# === JWT / Auth ===
SECRET_KEY=INSECURE-CHANGE-ME-IN-PRODUCTION-V1
JWT_AUDIENCE=api.b2p.com
JWT_ISSUER=auth.b2p.com
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# === Security ===
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# === Rate limiting ===
RATE_LIMIT_AUTH=30

# === Account lockout ===
MAX_FAILED_LOGIN_ATTEMPTS=5
LOCK_MINUTES=15

# === SMTP / Email ===
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USERNAME=resend
SMTP_PASSWORD=
EMAIL_FROM=Byparsathy <onboarding@resend.dev>
FRONTEND_URL=http://localhost:3000

# Gmail SMTP (optional — takes precedence over Resend for dev/testing)
# Generate an App Password at myaccount.google.com -> Security -> App passwords.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# === AI (optional) ===
GROQ_API_KEY=

# === App ===
PROJECT_NAME=Byparsathy
API_V1_STR=/api/v1
PORT=8000
# NODE_ENV=production requires a non-default SECRET_KEY and a strong ADMIN_PASSWORD.
NODE_ENV=development

# === Admin seed (created on first boot) ===
# In production, the admin is only seeded when a strong ADMIN_PASSWORD is set.
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=admin123
